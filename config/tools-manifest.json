# ============================================================
# 工具下载清单 — JSON manifest
# 每个条目定义下载来源、目标路径、版本获取方式
# ============================================================
{
  "tools": {
    "nuclei": {
      "repo": "projectdiscovery/nuclei",
      "asset_pattern": "nuclei_.*_windows_amd64\\.zip",
      "bin": "nuclei.exe",
      "category": "vuln-scan"
    },
    "naabu": {
      "repo": "projectdiscovery/naabu",
      "asset_pattern": "naabu_.*_windows_amd64\\.zip",
      "bin": "naabu.exe",
      "category": "port-scan"
    },
    "httpx": {
      "repo": "projectdiscovery/httpx",
      "asset_pattern": "httpx_.*_windows_amd64\\.zip",
      "bin": "httpx.exe",
      "category": "web-probe"
    },
    "subfinder": {
      "repo": "projectdiscovery/subfinder",
      "asset_pattern": "subfinder_.*_windows_amd64\\.zip",
      "bin": "subfinder.exe",
      "category": "subdomain"
    },
    "katana": {
      "repo": "projectdiscovery/katana",
      "asset_pattern": "katana_.*_windows_amd64\\.zip",
      "bin": "katana.exe",
      "category": "crawler"
    },
    "dnsx": {
      "repo": "projectdiscovery/dnsx",
      "asset_pattern": "dnsx_.*_windows_amd64\\.zip",
      "bin": "dnsx.exe",
      "category": "dns"
    },
    "tlsx": {
      "repo": "projectdiscovery/tlsx",
      "asset_pattern": "tlsx_.*_windows_amd64\\.zip",
      "bin": "tlsx.exe",
      "category": "tls"
    },
    "fscan": {
      "repo": "shadow1ng/fscan",
      "asset_pattern": "fscan.*\\.exe",
      "bin": "fscan.exe",
      "category": "port-scan",
      "note": "内网扫描神器，含爆破+POC"
    },
    "ffuf": {
      "repo": "ffuf/ffuf",
      "asset_pattern": "ffuf_.*_windows_amd64\\.zip",
      "bin": "ffuf.exe",
      "category": "fuzzer"
    },
    "gau": {
      "repo": "lc/gau",
      "asset_pattern": "gau_.*_windows_amd64\\.zip",
      "bin": "gau.exe",
      "category": "url-collector"
    },
    "jq": {
      "repo": "jqlang/jq",
      "asset_pattern": "jq-windows-amd64\\.exe",
      "bin": "jq.exe",
      "category": "util",
      "rename": true
    },
    "dalfox": {
      "repo": "hahwul/dalfox",
      "asset_pattern": "dalfox_.*_windows_amd64\\.tar\\.gz",
      "bin": "dalfox.exe",
      "category": "xss-scanner",
      "note": "XSS 专项扫描器，专精参数分析+DOM XSS"
    }
  },
  "cloned_tools": {
    "PEASS-ng": {
      "repo": "carlospolop/PEASS-ng",
      "target": "tools/peass-ng",
      "category": "privilege-escalation",
      "note": "Linux/Windows 系统化提权辅助脚本 (linpeas.sh / winpeas.exe)"
    },
    "SSTImap": {
      "repo": "vladko312/SSTImap",
      "target": "tools/sstimap",
      "category": "ssti",
      "note": "SSTI 自动检测与利用工具"
    },
    "SpiderX": {
      "repo": "LiChaser/SpiderX",
      "target": "tools/spiderx",
      "category": "js-reverse",
      "note": "前端 JS 加密自动化绕过"
    },
    "MemShellParty": {
      "repo": "ReaJason/MemShellParty",
      "target": "tools/MemShellParty",
      "category": "memshell",
      "note": "Java 内存马注入框架（需自行编译 jar）"
    },
    "JYso": {
      "repo": "qi4L/JYso",
      "target": "tools/JYso",
      "category": "jndi-deserialization",
      "note": "JNDI注入+反序列化+回显+内存马，替代旧版 JNDI-Injection-Exploit"
    }
  },
  "dictionaries": {
    "SecLists": {
      "repo": "danielmiessler/SecLists",
      "target": "config/dictionaries/SecLists",
      "note": "git clone --depth 1（精选核心文件）"
    },
    "SuperWordlist": {
      "repo": "CrackerCat/SuperWordlist",
      "target": "config/dictionaries/SuperWordlist",
      "note": "git clone --depth 1"
    },
    "Dict": {
      "repo": "NS-Sp4ce/Dict",
      "target": "config/dictionaries/Dict",
      "note": "git clone --depth 1"
    },
    "SaiDict": {
      "repo": "R0B1NL1N/SaiDict",
      "target": "config/dictionaries/SaiDict",
      "note": "git clone --depth 1"
    },
    "S-BlastingDictionary": {
      "repo": "rootm0s/S-BlastingDictionary",
      "target": "config/dictionaries/S-BlastingDictionary",
      "note": "git clone --depth 1"
    }
  }
}
